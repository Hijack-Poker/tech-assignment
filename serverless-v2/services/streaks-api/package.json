{
  "name": "@hijack/streaks-api",
  "version": "1.0.0",
  "private": true,
  "description": "Streaks API — Serverless Lambda with Express",
  "scripts": {
    "start": "npx serverless offline --config serverless.offline.yml --host 0.0.0.0",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --forceExit",
    "seed": "node scripts/seed.js"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.500.0",
    "@aws-sdk/lib-dynamodb": "^3.500.0",
    "express": "^4.18.0",
    "ioredis": "^5.3.0",
    "mysql2": "^3.9.0",
    "sequelize": "^6.37.0",
    "serverless": "^3.39.0",
    "serverless-http": "^3.2.0",
    "serverless-offline": "^13.3.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js",
      "**/__tests__/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.ts$": "ts-jest"
    }
  }
}
